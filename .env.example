# NeuralForge Environment Variables
# Copy to .env and fill in your values

# Anthropic Claude (for AI Assistant)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Weights & Biases for experiment tracking
WANDB_API_KEY=
WANDB_PROJECT=neural-forge

# Training defaults
NEURALFORGE_DEVICE=auto
NEURALFORGE_PRECISION=bf16
NEURALFORGE_LOG_LEVEL=INFO
